# =============================================================================
# Personal Web Application - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env file to version control!

# =============================================================================
# AWS Credentials
# =============================================================================
# AWS Access Key ID for Bedrock and other AWS services
PERSONAL_AWS_ACCESS_KEY_ID=

# AWS Secret Access Key
PERSONAL_AWS_SECRET_ACCESS_KEY=

# AWS Region (default: us-east-1)
PERSONAL_AWS_REGION=us-east-1

# =============================================================================
# Skatetricks Upload / Transcoding
# =============================================================================
# Max browser-upload size accepted by the app and presign endpoint
SKATETRICKS_UPLOAD_MAX_FILE_SIZE=500MB

# Lifetime of the presigned S3 upload URL
SKATETRICKS_UPLOAD_PRESIGN_DURATION=15m

# Optional override for the S3 bucket that receives raw uploaded skate videos
# Defaults to the CDN processed-media bucket if left unset
SKATETRICKS_TRANSCODING_INPUT_BUCKET=

# Optional override for the S3 bucket that stores transcoded MP4 outputs
# Defaults to the CDN processed-media bucket if left unset
SKATETRICKS_TRANSCODING_OUTPUT_BUCKET=

# MediaConvert execution role ARN created by the HomeWeb CDK stack
SKATETRICKS_MEDIACONVERT_ROLE_ARN=

# Optional explicit MediaConvert endpoint; leave blank to use DescribeEndpoints
SKATETRICKS_MEDIACONVERT_ENDPOINT=

# Optional CDN override for Skatetricks output playback URLs
SKATETRICKS_CDN_DOMAIN=https://cdn.thonbecker.com

# =============================================================================
# Nextcloud CalDAV Integration
# =============================================================================
# Nextcloud username for calendar access
PERSONAL_NEXTCLOUD_USERNAME=

# Nextcloud app password (generate in Settings > Security > App passwords)
PERSONAL_NEXTCLOUD_APP_PASSWORD=

# =============================================================================
# AWS Cognito OAuth2 Authentication
# =============================================================================
# Cognito User Pool ID
PERSONAL_COGNITO_USER_POOL_ID=

# Cognito App Client ID
PERSONAL_COGNITO_CLIENT_ID=

# Cognito App Client Secret
PERSONAL_COGNITO_CLIENT_SECRET=

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================
# Database Username
PERSONAL_DB_USERNAME=postgres

# Database Password
PERSONAL_DB_PASSWORD=

# =============================================================================
# Perenual Plant API
# =============================================================================
# API key for Perenual plant identification (https://perenual.com/docs/api)
PERSONAL_PERENUAL_API_KEY=
