# =============================================================================
# Personal Web Application - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env file to version control!

# =============================================================================
# AWS Credentials
# =============================================================================
# AWS Access Key ID for Bedrock and other AWS services
AWS_ACCESS_KEY_ID=

# AWS Secret Access Key
AWS_SECRET_ACCESS_KEY=

# AWS Region (default: us-east-1)
AWS_REGION=us-east-1

# =============================================================================
# Nextcloud CalDAV Integration
# =============================================================================
# Nextcloud username for calendar access
NEXTCLOUD_USERNAME=

# Nextcloud app password (generate in Settings > Security > App passwords)
NEXTCLOUD_APP_PASSWORD=

# =============================================================================
# AWS Cognito OAuth2 Authentication
# =============================================================================
# Cognito User Pool ID
COGNITO_USER_POOL_ID=

# Cognito App Client ID
COGNITO_CLIENT_ID=

# Cognito App Client Secret
COGNITO_CLIENT_SECRET=

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================
# Database Username
DB_USERNAME=postgres

# Database Password
DB_PASSWORD=

# =============================================================================
# Perenual Plant API
# =============================================================================
# API key for Perenual plant identification (https://perenual.com/docs/api)
PERENUAL_API_KEY=

