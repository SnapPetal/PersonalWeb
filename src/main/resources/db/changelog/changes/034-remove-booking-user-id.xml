<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="034-remove-booking-user-id" author="codex">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="bookings" schemaName="booking" columnName="user_id"/>
        </preConditions>
        <comment>Bookings are public and are not associated with application users</comment>
        <dropIndex indexName="idx_bookings_user_id" tableName="bookings" schemaName="booking"/>
        <dropColumn tableName="bookings" schemaName="booking" columnName="user_id"/>
    </changeSet>
</databaseChangeLog>
