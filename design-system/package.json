{
  "name": "@thonbecker/personal-design-system",
  "private": true,
  "type": "module",
  "scripts": {
    "format:css": "prettier --write \"src/main/resources/**/*.css\"",
    "lint": "eslint . --no-error-on-unmatched-pattern && npm run lint:css",
    "lint:css": "prettier --check \"src/main/resources/**/*.css\" && stylelint \"src/main/resources/**/*.css\""
  },
  "devDependencies": {
    "eslint": "~8.57.1",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-config-prettier": "~10.1.8",
    "eslint-plugin-import": "~2.32.0",
    "prettier": "~3.9.4",
    "stylelint": "~17.14.0",
    "stylelint-config-standard": "40.0.0"
  }
}
