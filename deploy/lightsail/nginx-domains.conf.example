# Reference configuration for the host-managed nginx in nextcloud-aws.
# The production copies belong in nextcloud-aws/nginx, where Certbot adds TLS.

server {
    listen 80;
    server_name thonbecker.biz www.thonbecker.biz;

    root /var/www/thonbecker-static;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }
}

server {
    listen 80;
    server_name booking.thonbecker.biz;
    client_max_body_size 10M;

    location = / {
        return 302 /booking;
    }

    location ~ ^/(booking(?:/|$)|css/|js/|images/|webjars/|error$) {
        proxy_pass http://127.0.0.1:3003;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        return 404;
    }
}

server {
    listen 80;
    server_name app.thonbecker.biz;
    client_max_body_size 500M;

    location / {
        proxy_pass http://127.0.0.1:3003;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
